#define NLMS_FREQ_MIN_HZ 100.0f        // 有效频率下限
#define NLMS_FREQ_MAX_HZ 5000.0f       // 有效频率上限

#define NOISE_MONITOR_ALPHA (0.05f) // 基线更新速度，越小记忆越长
#define NOISE_WARMUP_BLOCKS 8       // reset 后先热身几块
