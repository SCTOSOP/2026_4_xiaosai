#define NOISE_MONITOR_ON 0    // 1: 启用噪声变化检测并触发 NLMS reset
#define HIGH_PASS_FILTER_ON 0 // 1: DAC 输出前经过高通滤波
#define NLMS_CUSTOM_INIT_ON 1 // 1: 使用 nlms_initial_w 初始化权重；0: 权重全 0
